%% Mermaid Network Topology Diagram - Home Lab Detail View
%% Detail architecture: Hyper-V switches, site routers, node groups, and uplink path.

flowchart LR
  classDef router fill:#f5d0a9,stroke:#9a3412,stroke-width:2px,color:#1f2937
  classDef sw fill:#dbe4ee,stroke:#334155,stroke-width:1.5px,color:#0f172a
  classDef nodegroup fill:#dbeafe,stroke:#1d4ed8,stroke-width:1.5px,color:#0f172a
  classDef map fill:#ecfeff,stroke:#0e7490,stroke-width:1.5px,color:#0f172a
  classDef ext fill:#fee2e2,stroke:#991b1b,stroke-width:2px,color:#1f2937

  subgraph DC1 [dc1 Site]
    direction TB
    d1k["vSwitch-dc1-kubes<br/>10.1.4.0/24"]
    d1s["vSwitch-dc1-storage<br/>172.16.10.0/24"]
    d1d["vSwitch-dc1-domain<br/>192.168.1.0/24"]
    d1g["vSwitch-dc1-seg1<br/>1.1.0.0/24"]
    r1["VyOS: router-dc1<br/>GW: .1 on each dc1 subnet"]

    d1map["dc1 NIC map<br/>eth0 -> kubes<br/>eth1 -> storage<br/>eth2 -> domain<br/>eth3 -> seg1"]
    d1nodes["dc1 nodes (6)<br/>dc1manager-ctrl01<br/>dc1manager-work01<br/>dc1manager-work02<br/>dc1domain-ctrl01<br/>dc1domain-work01<br/>dc1domain-work02"]

    d1k --> r1
    d1s --> r1
    d1d --> r1
    d1g --> r1

    d1nodes --> d1map
    d1map --> d1k
    d1map --> d1s
    d1map --> d1d
    d1map --> d1g
  end

  subgraph DC2 [dc2 Site]
    direction TB
    d2k["vSwitch-dc2-kubes<br/>10.2.4.0/24"]
    d2s["vSwitch-dc2-storage<br/>172.16.20.0/24"]
    d2d["vSwitch-dc2-domain<br/>192.168.2.0/24"]
    d2g["vSwitch-dc2-seg1<br/>1.2.0.0/24"]
    r2["VyOS: router-dc2<br/>GW: .1 on each dc2 subnet"]

    d2map["dc2 NIC map<br/>eth0 -> kubes<br/>eth1 -> storage<br/>eth2 -> domain<br/>eth3 -> seg1"]
    d2nodes["dc2 nodes (3)<br/>dc2domain-ctrl01<br/>dc2domain-work01<br/>dc2domain-work02"]

    d2k --> r2
    d2s --> r2
    d2d --> r2
    d2g --> r2

    d2nodes --> d2map
    d2map --> d2k
    d2map --> d2s
    d2map --> d2d
    d2map --> d2g
  end

  subgraph DC3 [dc3 Site]
    direction TB
    d3k["vSwitch-dc3-kubes<br/>10.3.4.0/24"]
    d3s["vSwitch-dc3-storage<br/>172.16.30.0/24"]
    d3d["vSwitch-dc3-domain<br/>192.168.3.0/24"]
    d3g["vSwitch-dc3-seg1<br/>1.3.0.0/24"]
    r3["VyOS: router-dc3<br/>GW: .1 on each dc3 subnet"]

    d3map["dc3 NIC map<br/>eth0 -> kubes<br/>eth1 -> storage<br/>eth2 -> domain<br/>eth3 -> seg1"]
    d3nodes["dc3 nodes (3)<br/>dc3domain-ctrl01<br/>dc3domain-work01<br/>dc3domain-work02"]

    d3k --> r3
    d3s --> r3
    d3d --> r3
    d3g --> r3

    d3nodes --> d3map
    d3map --> d3k
    d3map --> d3s
    d3map --> d3d
    d3map --> d3g
  end

  transit["vSwitch-transit<br/>10.254.0.0/24"]
  central["VyOS: router-center<br/>10.254.0.1"]
  extsw["cotpa-vlans_vsw<br/>external switch"]
  internet[["Internet"]]

  r1 -->|10.254.0.2 transit| transit
  r2 -->|10.254.0.3 transit| transit
  r3 -->|10.254.0.4 transit| transit
  transit --> central

  extsw --> central
  central -->|VLAN 9 egress| internet

  class r1,r2,r3,central router
  class d1k,d1s,d1d,d1g,d2k,d2s,d2d,d2g,d3k,d3s,d3d,d3g,transit sw
  class d1nodes,d2nodes,d3nodes nodegroup
  class d1map,d2map,d3map map
  class extsw,internet ext

  click central "../scripts/create-vyos-routers.ps1" "Router provisioning script"
  click d1nodes "../configs/home-lab/nodes/dc1manager-work02.yaml" "dc1 work02 manifest"
  click d2nodes "../configs/home-lab/nodes/dc2domain-work02.yaml" "dc2 work02 manifest"
  click d3nodes "../configs/home-lab/nodes/dc3domain-work02.yaml" "dc3 work02 manifest"
