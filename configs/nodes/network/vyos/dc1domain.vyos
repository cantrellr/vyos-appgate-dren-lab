# VyOS fragment for dc1domain router interfaces
set interfaces ethernet eth0 description 'kubes-domain'
set interfaces ethernet eth0 address '10.1.4.129/24'

set interfaces ethernet eth1 description 'netapp-1001'
set interfaces ethernet eth1 address '172.16.10.108/24'

set interfaces ethernet eth2 description 'domain'
set interfaces ethernet eth2 address '192.168.1.129/24'

set interfaces ethernet eth3 description 'segment1'
set interfaces ethernet eth3 address '1.1.0.129/25'
