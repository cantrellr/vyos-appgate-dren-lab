## VyOS fragment for Central Transit Router
# Transit network to site routers: 10.254.0.0/24
set interfaces ethernet eth0 description 'transit'
set interfaces ethernet eth0 address '10.254.0.1/24'

# Uplink to Internet (example: DHCP or static). Replace with real adapter addressing.
set interfaces ethernet eth1 description 'uplink'
# set interfaces ethernet eth1 address '203.0.113.10/24'
# set protocols static route 0.0.0.0/0 next-hop 203.0.113.1

# NAT: masquerade internal-site networks via uplink
set nat source rule 100 outbound-interface 'eth1'
set nat source rule 100 source address '10.0.0.0/8'
set nat source rule 100 translation address 'masquerade'
set nat source rule 101 outbound-interface 'eth1'
set nat source rule 101 source address '172.16.0.0/12'
set nat source rule 101 translation address 'masquerade'
set nat source rule 102 outbound-interface 'eth1'
set nat source rule 102 source address '192.168.0.0/16'
set nat source rule 102 translation address 'masquerade'
set nat source rule 103 outbound-interface 'eth1'
set nat source rule 103 source address '1.0.0.0/8'
set nat source rule 103 translation address 'masquerade'

# Basic firewall rules could be added here if desired.
