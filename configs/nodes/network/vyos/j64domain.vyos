# VyOS fragment for j64domain router interfaces
set interfaces ethernet eth0 description 'kubes-domain'
set interfaces ethernet eth0 address '10.0.4.129/24'

set interfaces ethernet eth1 description 'netapp-1001'
set interfaces ethernet eth1 address '172.16.0.108/24'

set interfaces ethernet eth2 description 'segment1'
set interfaces ethernet eth2 address '1.0.0.129/25'
