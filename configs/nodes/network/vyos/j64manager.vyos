# VyOS fragment for j64manager router interfaces
set interfaces ethernet eth0 description 'kubes-domain'
set interfaces ethernet eth0 address '10.0.4.1/24'

set interfaces ethernet eth1 description 'netapp-1001'
set interfaces ethernet eth1 address '172.16.0.1/24'

set interfaces ethernet eth2 description 'segment1'
set interfaces ethernet eth2 address '1.0.0.129/25'

# Example static routes (adjust as needed)
# set protocols static route 10.0.4.0/24 next-hop 10.0.4.2
