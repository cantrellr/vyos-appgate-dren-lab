# VyOS fragment for dc1manager router (includes uplink NAT for Internet egress)
set interfaces ethernet eth0 description 'kubes-domain'
set interfaces ethernet eth0 address '10.1.4.1/24'

set interfaces ethernet eth1 description 'netapp-1001'
set interfaces ethernet eth1 address '172.16.10.1/24'

set interfaces ethernet eth2 description 'domain'
set interfaces ethernet eth2 address '192.168.1.1/24'

set interfaces ethernet eth3 description 'segment1'
set interfaces ethernet eth3 address '1.1.0.129/25'

# Uplink interface to Internet (example: DHCP or static)
set interfaces ethernet eth4 description 'transit'
set interfaces ethernet eth4 address '10.254.0.11/24'

# Default route via Central Transit Router
set protocols static route 0.0.0.0/0 next-hop '10.254.0.1'

# NOTE: NAT/egress is handled by the central transit router (central-router.vyos)
